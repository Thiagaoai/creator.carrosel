# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-secret
# Comma-separated list of allowed Telegram user IDs
ALLOWED_TELEGRAM_USER_IDS=123456789

# ── External APIs ─────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
FAL_KEY=
POSTFORME_API_KEY=
# Post for Me social account id (from dashboard: spc_… / sa_…). Used if brand_presets.instagram_account_id is empty.
POSTFORME_DEFAULT_SOCIAL_ACCOUNT_ID=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_SCHEMA=carousel_autoposter

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Public URL where FastAPI is reachable (used to register Telegram webhook)
PUBLIC_WEBHOOK_URL=https://your-domain.example.com
REGISTER_WEBHOOK=true
MAX_COST_PER_CAROUSEL_USD=1.50
